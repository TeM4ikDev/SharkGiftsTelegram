# Скопируйте в .env.development (разработка) или .env.production (продакшен).
# Либо скопируйте в .env — он подгружается после режимного файла.

NODE_ENV=development
# Для продакшена: NODE_ENV=production

# База данных
# Разработка (локально):
DATABASE_URL="file:./prisma/dev.db"
# Продакшен (Docker задаёт сам): file:/app/data/dev.db

# JWT и шифрование
JWT_SECRET=your-secret-key
ENCRYPTION_KEY=your-base64-encryption-key
JWT_EXPIRES_IN=7d

# Разработка: мок Telegram (true/false)
ALLOW_MOCK_TELEGRAM_DATA=true

# Telegram Bot
BOT_TOKEN=your-bot-token
BOT_USERNAME=@YourBot

# Платежи
TARGET_WALLET_ADDRESS=your-ton-wallet
CRYPTOBOT_API_TOKEN=your-cryptobot-token
# TON_API_KEY=optional-ton-api-key
